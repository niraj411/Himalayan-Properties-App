generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  role          String    @default("TENANT") // ADMIN or TENANT
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant?
  reminders     Reminder[]
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")
}

model Property {
  id          String   @id @default(cuid())
  name        String
  type        String   // RESIDENTIAL or COMMERCIAL
  address     String
  city        String
  state       String
  zip         String
  description String?
  imageUrl    String?
  photos      String?  // JSON array of additional image URLs
  zillowUrl   String?
  mortgageLender          String?
  mortgageMonthlyPayment  Float?
  mortgageDueDay          Int?
  mortgageBalance         Float?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  units        Unit[]
  applications Application[]
  utilities    Utility[]
}

model Unit {
  id         String   @id @default(cuid())
  propertyId String
  unitNumber String
  bedrooms   Int?
  bathrooms  Float?
  sqft       Int?
  rent       Float
  status     String   @default("VACANT") // VACANT, OCCUPIED, MAINTENANCE
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property            Property             @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenants             Tenant[]
  leases              Lease[]
  maintenanceRequests MaintenanceRequest[]
  utilities           Utility[]

  @@unique([propertyId, unitNumber])
}

// Per-property utility / service providers (trash, electric, water, HOA, etc.).
// Primarily tenant-facing (onboarding directory + utility notices). Admin-only
// fields (accountNumber, monthlyCost, dueDay, internalNotes) must never be sent
// to tenants. unitId null = whole property; set = override for one unit.
model Utility {
  id            String   @id @default(cuid())
  propertyId    String
  unitId        String?  // null = whole property; set = specific-unit override
  type          String   // TRASH, ELECTRIC, WATER, SEWER, GAS, HOA, INTERNET, OTHER
  providerName  String
  phone         String?
  website       String?
  accountNumber String?  // ADMIN-ONLY
  monthlyCost   Float?   // ADMIN-ONLY
  dueDay        Int?     // ADMIN-ONLY (1-31); reserved for future reminders
  tenantNotes   String?  // TENANT-VISIBLE (trash schedule, can codes, setup steps)
  internalNotes String?  // ADMIN-ONLY
  tenantVisible Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  unit     Unit?    @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}

model Tenant {
  id               String    @id @default(cuid())
  userId           String    @unique
  unitId           String?
  moveInDate       DateTime?
  moveOutDate      DateTime?
  emergencyContact String?
  emergencyPhone   String?
  baselaneLink     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  unit                Unit?                @relation(fields: [unitId], references: [id])
  leases              Lease[]
  coLeases            Lease[]              @relation("LeaseCoTenants")
  maintenanceRequests MaintenanceRequest[]
}

model Lease {
  id            String   @id @default(cuid())
  tenantId      String
  unitId        String
  leaseType     String   @default("RESIDENTIAL") // RESIDENTIAL or COMMERCIAL
  startDate     DateTime
  endDate       DateTime
  monthlyRent   Float
  nnnMonthly    Float?   // NNN/CAM additional rent per month (triple-net commercial leases); base rent is monthlyRent
  depositAmount Float?
  documentUrl   String?
  status        String   @default("ACTIVE") // ACTIVE, EXPIRED, TERMINATED
  insuranceRequired Boolean @default(true) // soft flag; admins can exempt a lease from insurance tracking
  notes         String?
  depositPaidDate      DateTime?
  depositStatus        String?   // HELD, RETURNED, PARTIAL_RETURN
  depositReturnDate    DateTime?
  depositReturnAmount  Float?
  depositDeductionNotes String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit        Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  coTenants   Tenant[]         @relation("LeaseCoTenants")
  payments    Payment[]
  escalations LeaseEscalation[]
  insurance   InsuranceRecord[]
  charges     Charge[]
  notices     Notice[]
}

// Outbound notices (late/demand/eviction) emailed to tenants through the app.
// Each send is logged here so it's viewable, auditable, and re-sendable.
model Notice {
  id        String   @id @default(cuid())
  leaseId   String
  type      String   // LATE, DEMAND, CO_DEMAND, CUSTOM
  subject   String
  body      String   // rendered plain text (what was emailed)
  toEmail   String
  ccEmails  String?  // comma-separated
  replyTo   String?
  amountDue Float?   // snapshot of open-charge balance at send time
  status    String   @default("SENT") // SENT, FAILED
  messageId String?  // SMTP message id
  errorText String?
  sentById  String?
  sentAt    DateTime @default(now())

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId, sentAt])
}

// One-off / outstanding charges billed to a lease (rent owed, late fees,
// utilities, final move-out invoices). Source of truth for balances is
// Baselane (no API), so these are entered/maintained here by admins.
model Charge {
  id        String    @id @default(cuid())
  leaseId   String
  kind      String    @default("OTHER") // RENT, LATE_FEE, UTILITY, FINAL, CLEANING, DEPOSIT, OTHER
  label     String
  amount    Float
  dueDate   DateTime?
  status    String    @default("OPEN") // OPEN, PAID, WAIVED
  source    String?   // e.g. "Baselane #1341810"
  notes     String?
  paidDate  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)

  @@index([leaseId, status])
}

// Lease escalations for commercial properties
model LeaseEscalation {
  id              String   @id @default(cuid())
  leaseId         String
  effectiveDate   DateTime
  newMonthlyRent  Float
  increaseType    String   // PERCENTAGE, FIXED_AMOUNT, CPI
  increaseValue   Float?   // e.g., 3 for 3% or 100 for $100
  notes           String?
  applied         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)
}

// Insurance tracking for all tenants (residential renters insurance + commercial liability)
model InsuranceRecord {
  id                  String    @id @default(cuid())
  leaseId             String
  insuranceType       String    @default("LIABILITY") // RENTERS, LIABILITY, PROPERTY, WORKERS_COMP
  interestType        String    @default("ADDITIONAL_INTEREST") // ADDITIONAL_INTEREST (residential) or ADDITIONAL_INSURED (commercial)
  carrier             String?
  policyNumber        String?
  coverageAmount      Float?
  effectiveDate       DateTime
  expirationDate      DateTime
  documentUrl         String?
  beneficiaryName     String    @default("Himalayan Holdings Property LLC")
  verified            Boolean   @default(false)
  verifiedAt          DateTime?
  reminderSent        Boolean   @default(false)
  reminderSentAt      DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)
}

model Message {
  id      String   @id @default(cuid())
  fromId  String?
  toId    String?
  subject String
  body    String
  sentAt  DateTime @default(now())

  from User? @relation("SentMessages", fields: [fromId], references: [id])
  to   User? @relation("ReceivedMessages", fields: [toId], references: [id])
}

model Application {
  id              String   @id @default(cuid())
  propertyId      String?
  applicationType String   @default("RESIDENTIAL") // RESIDENTIAL or COMMERCIAL
  firstName       String
  lastName        String
  email           String
  phone           String
  currentAddress  String?
  employerName    String?
  employerPhone   String?
  jobTitle        String?
  monthlyIncome   Float?
  moveInDate      DateTime?
  numberOfOccupants Int?
  pets            String?
  references      String?
  additionalNotes String?
  // Commercial application fields
  businessName        String?
  taxReturnsUrl       String?  // 2 years of corporate tax returns
  bankStatementsUrl   String?  // 3 months of bank statements
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  property Property? @relation(fields: [propertyId], references: [id])
}

model MaintenanceRequest {
  id          String   @id @default(cuid())
  tenantId    String
  unitId      String
  title       String
  description String
  category    String?  // PLUMBING, ELECTRICAL, HVAC, APPLIANCE, OTHER
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, EMERGENCY
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED, CANCELLED
  imageUrls   String?  // JSON array of image URLs
  notes       String?
  contractor    String?  // who did the work
  repairCost    Float?   // total cost billed when completed
  paymentMethod String?  // VENMO, CHECK, CASH, OTHER — how the contractor was paid
  paymentAccount String? // account/reference (e.g. Venmo handle, check #)
  chargeId      String?  // Charge created from this repair, if any (prevents duplicates)
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit   Unit   @relation(fields: [unitId], references: [id], onDelete: Cascade)
}

model Payment {
  id        String   @id @default(cuid())
  leaseId   String
  amount    Float
  date      DateTime
  method    String?  // BANK_TRANSFER, CHECK, CASH, OTHER
  reference String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lease Lease @relation(fields: [leaseId], references: [id], onDelete: Cascade)
}

model Reminder {
  id        String   @id @default(cuid())
  userId    String
  type      String   // LEASE_EXPIRY, RENT_DUE, MAINTENANCE, CUSTOM
  title     String
  message   String?
  dueDate   DateTime
  entityId  String?  // ID of related entity (lease, maintenance request, etc.)
  completed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Settings {
  id             String  @id @default(cuid())
  companyName    String  @default("Himalayan Properties")
  companyEmail   String?
  companyPhone   String?
  companyAddress String?
  bankName       String?
  bankRoutingNumber String?
  bankAccountNumber String?
  checkMailingAddress String?
  paymentInstructions String?
  baselanePaymentLink String?
  zillowUrl           String?
  emailNotificationsEnabled Boolean @default(false)
  insuranceReminderEnabled  Boolean @default(true)
  insuranceReminderLeadDays Int     @default(30)
}

// QuickBooks Integration
model QuickBooksToken {
  id            String   @id @default(cuid())
  realmId       String   @unique
  accessToken   String
  refreshToken  String
  accessTokenExpiresAt  DateTime
  refreshTokenExpiresAt DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
